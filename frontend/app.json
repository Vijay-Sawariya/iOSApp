{
  "expo": {
    "name": "Sagar Home",
    "slug": "sagar-home",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sagarhome",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sagarhomelms.lms",
      "buildNumber": "20",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of properties",
        "NSPhotoLibraryUsageDescription": "Upload property images",
        "NSPhotoLibraryAddUsageDescription": "Save property images to Photos",
        "NSLocationWhenInUseUsageDescription": "Get property location for Google Maps",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sagarhome.lms",
      "versionCode": 16,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload property images",
          "cameraPermission": "Take photos of properties"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Upload property images",
          "savePhotosPermission": "Save property images to Photos"
        }
      ],
      "expo-document-picker",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Get property location for Google Maps"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a0d442af-30a8-4e41-8033-d84dc2d3dbb8"
      },
      "router": {}
    },
    "owner": "vsawariya"
  }
}
